{
  "name": "lighthouse-insights-action",
  "version": "1.0.0",
  "description": "GitHub Action for running Lighthouse CI audits and generating human-friendly reports",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "local": "node --import tsx scripts/run-local.ts",
    "local:fixture": "node --import tsx scripts/run-local.ts --fixture",
    "local:fixture:pr": "node --import tsx scripts/run-local.ts --fixture --pr --production-report fixtures/prod-lighthouse-report.md --out local-pr-lighthouse-report.md",
    "local:report": "node --import tsx scripts/run-local.ts --skip-collect",
    "local:live": "node --import tsx scripts/run-local.ts https://aman-kumar.dev --out prod-lighthouse-report.md",
    "local:domains:dry": "node --import tsx scripts/run-local.ts --dry-run --paths /,/about --production-domain https://aman-kumar.dev --staging-domain https://aman-kumar-blogs-git-main-amankumarrrs-projects.vercel.app",
    "local:default:dry": "node --import tsx scripts/run-local.ts --dry-run --paths /,/about --default-domain https://aman-kumar.dev",
    "local:domains": "node --import tsx scripts/run-local.ts --paths /,/about --production-domain https://aman-kumar.dev --staging-domain https://aman-kumar-blogs-git-main-amankumarrrs-projects.vercel.app --out local-both-domains-report.md",
    "local:default": "node --import tsx scripts/run-local.ts --paths /,/about --default-domain https://aman-kumar.dev --out local-default-domain-report.md",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["github-actions", "lighthouse", "lighthouse-ci", "performance"],
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^4.0.0",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@lhci/cli": "^0.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.30",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
